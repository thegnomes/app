# Vercel Blob / CDN base URL for media assets
# Set this when hosting portfolio media on Vercel Blob or an external CDN.
# Leave empty to use local public/ files.
#
# Example with Vercel Blob:
# VITE_ASSET_BASE_URL=https://xxx.public.blob.vercel-storage.com
#
# Example with Cloudinary:
# VITE_ASSET_BASE_URL=https://res.cloudinary.com/your-cloud/raw/upload
VITE_ASSET_BASE_URL=
